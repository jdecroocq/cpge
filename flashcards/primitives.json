{
  "title": "Primitives usuelles (mémo)",
  "labelA": "Fonction",
  "labelB": "Primitive",
  "cards": [
    { "a": "$k$", "b": "$kx + C$" },

    { "a": "$x^n,\\ n \\neq -1$", "b": "$\\dfrac{x^{n+1}}{n+1} + C$" },
    { "a": "$\\dfrac{1}{x}$", "b": "$\\ln|x| + C$" },

    { "a": "$e^x$", "b": "$e^x + C$" },
    { "a": "$a^x$", "b": "$\\dfrac{a^x}{\\ln a} + C$" },

    { "a": "$\\cos x$", "b": "$\\sin x + C$" },
    { "a": "$\\sin x$", "b": "$-\\cos x + C$" },
    { "a": "$\\tan x$", "b": "$-\\ln|\\cos x| + C$" },

    { "a": "$\\mathrm{ch}\\,x$", "b": "$\\mathrm{sh}\\,x + C$" },
    { "a": "$\\mathrm{sh}\\,x$", "b": "$\\mathrm{ch}\\,x + C$" },
    { "a": "$\\mathrm{th}\\,x$", "b": "$\\ln(\\mathrm{ch}\\,x) + C$" },

    { "a": "$\\ln x$", "b": "$x\\ln x - x + C$" },

    { "a": "$u'(x)\\,u(x)^n,\\ n \\neq -1$", "b": "$\\dfrac{u(x)^{n+1}}{n+1} + C$" },
    { "a": "$\\dfrac{u'(x)}{u(x)}$", "b": "$\\ln|u(x)| + C$" },

    { "a": "$u'(x)e^{u(x)}$", "b": "$e^{u(x)} + C$" },
    { "a": "$u'(x)\\cos(u(x))$", "b": "$\\sin(u(x)) + C$" },
    { "a": "$u'(x)\\sin(u(x))$", "b": "$-\\cos(u(x)) + C$" },
    { "a": "$u'(x)\\tan(u(x))$", "b": "$-\\ln|\\cos(u(x))| + C$" },

    { "a": "$u'(x)\\mathrm{ch}(u(x))$", "b": "$\\mathrm{sh}(u(x)) + C$" },
    { "a": "$u'(x)\\mathrm{sh}(u(x))$", "b": "$\\mathrm{ch}(u(x)) + C$" },
    { "a": "$u'(x)\\mathrm{th}(u(x))$", "b": "$\\ln(\\mathrm{ch}(u(x))) + C$" },

    { "a": "$u'(x)f(u(x))$", "b": "$F(u(x)) + C \\quad (F' = f)$" }
  ]
}
