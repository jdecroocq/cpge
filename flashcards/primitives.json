{
  "title": "Primitives usuelles",
  "labelA": "Fonction",
  "labelB": "Primitive",
  "cards": [
    { "a": "$k$", "b": "$kx + C$" },

    { "a": "$x^n,\\ n \\neq -1$", "b": "$\\dfrac{1}{n+1}x^{n+1} + C$" },
    { "a": "$\\dfrac{1}{x}$", "b": "$\\ln|x| + C$" },

    { "a": "$e^x$", "b": "$e^x + C$" },
    { "a": "$b^x$", "b": "$\\dfrac{1}{\\ln b}\\,b^x + C$" },

    { "a": "$\\cos x$", "b": "$\\sin x + C$" },
    { "a": "$\\sin x$", "b": "$-\\cos x + C$" },
    { "a": "$\\tan x$", "b": "$-\\ln|\\cos x| + C$" },

    { "a": "$\\mathrm{ch}\\,x$", "b": "$\\mathrm{sh}\\,x + C$" },
    { "a": "$\\mathrm{sh}\\,x$", "b": "$\\mathrm{ch}\\,x + C$" },
    { "a": "$\\mathrm{th}\\,x$", "b": "$\\ln(\\mathrm{ch}\\,x) + C$" },

    { "a": "$\\ln x$", "b": "$x\\ln x - x + C$" },

    { "a": "$\\mathrm{Arcsin}\\,x$", "b": "$x\\,\\mathrm{Arcsin}\\,x + \\sqrt{1-x^2} + C$" },
    { "a": "$\\mathrm{Arccos}\\,x$", "b": "$x\\,\\mathrm{Arccos}\\,x - \\sqrt{1-x^2} + C$" },
    { "a": "$\\mathrm{Arctan}\\,x$", "b": "$x\\,\\mathrm{Arctan}\\,x - \\dfrac{1}{2}\\ln(1+x^2) + C$" },

    { "a": "$u' \\cdot u^n,\\ n \\neq -1$", "b": "$\\dfrac{1}{n+1}\\,(u)^{n+1} + C$" },
    { "a": "$\\dfrac{u'}{u}$", "b": "$\\ln|u| + C$" },

    { "a": "$u' \\cdot e^{u}$", "b": "$e^{u} + C$" },
    { "a": "$u' \\cdot \\cos(u)$", "b": "$\\sin(u) + C$" },
    { "a": "$u' \\cdot \\sin(u)$", "b": "$-\\cos(u) + C$" },
    { "a": "$u' \\cdot \\tan(u)$", "b": "$-\\ln|\\cos(u)| + C$" },

    { "a": "$u' \\cdot \\mathrm{ch}(u)$", "b": "$\\mathrm{sh}(u) + C$" },
    { "a": "$u' \\cdot \\mathrm{sh}(u)$", "b": "$\\mathrm{ch}(u) + C$" },
    { "a": "$u' \\cdot \\mathrm{th}(u)$", "b": "$\\ln(\\mathrm{ch}(u)) + C$" },

    { "a": "$u' \\cdot \\ln(u)$", "b": "$u\\ln(u) - u + C$" },

    { "a": "$u' \\cdot \\mathrm{Arcsin}(u)$", "b": "$u\\,\\mathrm{Arcsin}(u) + \\sqrt{1-u^2} + C$" },
    { "a": "$u' \\cdot \\mathrm{Arccos}(u)$", "b": "$u\\,\\mathrm{Arccos}(u) - \\sqrt{1-u^2} + C$" },
    { "a": "$u' \\cdot \\mathrm{Arctan}(u)$", "b": "$u\\,\\mathrm{Arctan}(u) - \\dfrac{1}{2}\\ln(1+u^2) + C$" }
  ]
}
