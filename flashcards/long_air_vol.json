{
  "title": "Longueurs, aires et volumes",
  "labelA": "Description",
  "labelB": "Formule",
  "cards": [
    {"a": "Longueur d'un cercle", "b": "$P = \\pi d = 2\\pi r$"},
    {"a": "Longueur d'un arc de cercle", "b": "$L = r\\theta$"},
    {"a": "Aire d'un parallélogramme", "b": "$A = b \\cdot h$"},
    {"a": "Aire d'un triangle", "b": "$A = \\frac{b \\cdot h}{2}$"},
    {"a": "Aire d'un trapèze", "b": "$A = \\frac{(B + b) \\cdot h}{2}$"},
    {"a": "Aire d'un polygone régulier", "b": "$A = \\frac{n l^2}{4 \\tan(\\\\\frac{\\\\pi}{l})}$"},
    {"a": "Aire d'un disque", "b": "$A = \\pi r^2$"},
    {"a": "Aire d'un secteur circulaire", "b": "$A = \\frac{1}{2} r^2 \\theta$"},
    {"a": "Aire latérale d'un cylindre de révolution", "b": "$A_{lat} = 2\\pi r h$"},
    {"a": "Aire latérale d'un cône de révolution", "b": "$A_{lat} = \\pi r g$ avec $g = \\sqrt{r^2 + h^2}$"},
    {"a": "Aire d'une sphère", "b": "$A = 4\\pi r^2$"},
    {"a": "Volume d'un prisme", "b": "$V = A_b \\cdot h$"},
    {"a": "Volume d'un cylindre de révolution", "b": "$V = \\pi r^2 h$"},
    {"a": "Volume d'une pyramide", "b": "$V = \\frac{1}{3} A_b \\cdot h$"},
    {"a": "Volume d'un cône de révolution", "b": "$V = \\frac{1}{3} \\pi r^2 h$"},
    {"a": "Volume d'une boule", "b": "$V = \\frac{4}{3} \\pi r^3$"}
  ]
}
